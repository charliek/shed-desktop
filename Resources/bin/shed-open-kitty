#!/bin/bash
# Open a new Kitty tab running the given command.
#
# Usage: shed-open-kitty <shed> <cmd>
#
# The new-tab path needs `allow_remote_control yes` in kitty.conf (so
# `kitty @` works). Without it we fall back to a new OS window (cold start).
# The kitty binary is resolved inside the app bundle (not on a GUI PATH).
set -euo pipefail

shed="${1:-}"
cmd="${2:-}"
[ -n "$cmd" ] || { echo "usage: shed-open-kitty <shed> <cmd>" >&2; exit 2; }

app_dir="$(/usr/bin/osascript -e 'POSIX path of (path to application id "net.kovidgoyal.kitty")' 2>/dev/null || true)"
KITTY="${app_dir%/}/Contents/MacOS/kitty"
[ -x "$KITTY" ] || { echo "kitty binary not found in kitty.app" >&2; exit 1; }

# Run the (already shell-quoted) ssh command through a shell so its quoting is
# preserved, rather than word-splitting it here.
if "$KITTY" @ ls >/dev/null 2>&1; then
  exec "$KITTY" @ launch --type=tab -- /bin/sh -lc "$cmd"
fi
# Cold start / remote control off: new OS window running the command.
exec /usr/bin/open -na "$app_dir" --args /bin/sh -lc "$cmd"
