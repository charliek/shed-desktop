{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shed Desktop",
  "version": "0.0.14",
  "identifier": "ai.stridelabs.shed-desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Shed Desktop",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "../../Resources/bin/shed-open-ghostty": "bin/shed-open-ghostty",
      "../../Resources/bin/shed-open-roost.py": "bin/shed-open-roost.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
